# Sanity Project Configuration
# Get these values from https://www.sanity.io/manage

# Your Sanity project ID (found in project settings)
SANITY_PROJECT_ID=your-project-id-here

# Dataset name (production, staging, etc.)
SANITY_DATASET=production

# Sanity API token (create one at https://www.sanity.io/manage/project/{projectId}/api)
# Required for server-side operations like RSS import
SANITY_API_TOKEN=your-api-token-here

# Webflow Configuration
# Create a Personal Access Token at https://webflow.com/settings/integrations
WEBFLOW_API_TOKEN=your-webflow-token-here

# Webflow Collection ID for press releases
# Found in Webflow CMS collection settings
WEBFLOW_COLLECTION_ID=your-collection-id-here

# Notte API Token (for web scraping)
# Get your API key at https://notte.cc
NOTTE_API_TOKEN=your-notte-api-token-here

# OpenAI API Key (for AI processing)
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# News Source URL (company news page)
NEWS_SOURCE_URL=https://www.prnewswire.com/news/your-company-slug/