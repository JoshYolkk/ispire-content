# Sanity Project Configuration
# Get these values from https://www.sanity.io/manage

# Your Sanity project ID (found in project settings)
SANITY_PROJECT_ID=your-project-id-here

# Dataset name (production, staging, etc.)
SANITY_DATASET=production

# Sanity API token (create one at https://www.sanity.io/manage/project/{projectId}/api)
# Required for server-side operations like RSS import
SANITY_API_TOKEN=your-api-token-here

# Webflow API Token (future use for syncing to Webflow CMS)
# WEBFLOW_API_TOKEN=your-webflow-token-here